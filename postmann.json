//1. create receipes
Request Method: POST
Sample Request Body:
{
  "title": "Paneer Butter Masala",
  "type": "Veg",
  "ingredients": [
    "paneer",
    "butter",
    "tomatoes",
    "onion",
    "cashew nuts",
    "cream",
    "ginger-garlic paste",
    "red chili powder",
    "turmeric",
    "garam masala",
    "coriander powder",
    "kasuri methi",
    "salt",
    "oil"
  ],
  "cookingTime": "40 minutes",
  "instructions": "Paneer Butter Masala is prepared by first making a rich gravy using tomatoes, onions, cashews, and spices, which is blended into a smooth paste. The gravy is then cooked with butter and cream to achieve a creamy texture. Cubes of paneer are added to the gravy and simmered gently. Finally, kasuri methi and fresh cream are added for flavor, and the dish is served hot with naan or rice."
}

